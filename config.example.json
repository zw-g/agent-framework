{
  "project": {
    "name": "VoiceInk",
    "repo": "zw-g/VoiceInk",
    "path": "~/.local/voice-input",
    "language": "python",
    "test_command": "cd ~/.local/voice-input && .venv-py2app/bin/python -c \"import py_compile; py_compile.compile('voice_input.py', doraise=True)\"",
    "lint_command": null,
    "build_command": null
  },
  "agents": {
    "researcher": {
      "personality": "agents/researcher.md",
      "max_turns": 30,
      "tools": "Read,Grep,Glob,Bash,WebSearch,WebFetch"
    },
    "critic": {
      "personality": "agents/critic.md",
      "max_turns": 15,
      "tools": "Read,Grep,Glob,WebSearch,WebFetch"
    },
    "executor": {
      "personality": "agents/executor.md",
      "max_turns": 50,
      "tools": "Read,Edit,Write,Grep,Glob,Bash"
    }
  },
  "workflow": {
    "max_debate_rounds": 3,
    "fast_path_labels": ["trivial"],
    "skip_labels": ["needs-human", "wontfix"],
    "priority_order": ["critical", "must-do", "bug", "should-do", "enhancement"],
    "create_pr": false,
    "direct_push": true,
    "branch_per_issue": false
  },
  "schedule": {
    "check_interval_minutes": 60,
    "max_issues_per_cycle": 3
  }
}
